{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'github>canonical/data-platform//renovate_presets/charm.json5',
  ],
  "lockFileMaintenance": {
    "enabled": true, 
    "schedule": ["* 1-5 * * 2"],  // Tuesday 01:00-05:00 UTC
    "groupName": "Python dependencies"
  },
  reviewers: [
    'team:data-postgresql',
  ],
  "enabledManagers": ["poetry", "pep621", "github-actions", "regex"],
  packageRules: [
    {
      "matchManagers": ["pep621"],
      "rangeStrategy": "in-range-only",
      "matchJsonata": [
          "depType = 'dependency-groups' and managerData.depGroup = 'libs'"
      ],
      "groupName": "Python dependencies"
    },
    {
      matchPackageNames: [
        'pydantic',
      ],
      allowedVersions: '<2.0.0',
    },
    {
      matchPackageNames: [
        'tenacity',
      ],
      allowedVersions: '<9.1',
    },
    {
      matchManagers: [
        'custom.regex',
      ],
      matchDepNames: [
        'juju',
      ],
      matchDatasources: [
        'pypi',
      ],
      allowedVersions: '<3',
      groupName: 'Juju agents',
    },
    {
      matchManagers: [
        'poetry',
      ],
      matchPackageNames: [
        'coverage',
      ],
      matchDatasources: [
        'pypi',
      ],
      enabled: false,
    },
  ],
  customManagers: [
    {
      customType: 'regex',
      managerFilePatterns: [
        '/^\\.github/workflows/[^/]+\\.ya?ml$/',
      ],
      matchStrings: [
        '(libjuju: )==(?<currentValue>.*?) +# renovate: latest libjuju 2',
      ],
      depNameTemplate: 'juju',
      datasourceTemplate: 'pypi',
      versioningTemplate: 'loose',
    },
  ],
}
